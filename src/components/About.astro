---
import { PERSON } from '../consts';
import { bindAI } from '../utils';
---

<section class="about" id="about">
  <div class="wrap">
    <div class="about__head">
      <span class="eyebrow" data-reveal>(01) — The Architect</span>
      <h2 class="about__title display" data-reveal>
        Building the<br />languages<br />machines speak.
      </h2>
    </div>

    <div class="about__body">
      {
        PERSON.bio.map((para, i) => (
          <p class="about__para" data-reveal style={`transition-delay:${i * 90}ms`}>
            {bindAI(para)}
          </p>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: clamp(5rem, 12vh, 11rem);
    border-top: 1px solid var(--line);
  }
  .about__head {
    display: grid;
    gap: 1.5rem;
    margin-bottom: clamp(2.5rem, 6vw, 5rem);
  }
  .about__title {
    font-size: clamp(2.2rem, 5vw, 4.2rem);
  }
  .about__body {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: clamp(1.5rem, 4vw, 3.5rem);
    max-width: 1300px;
    margin-left: auto;
  }
  .about__para {
    font-size: clamp(1rem, 1.25vw, 1.18rem);
    line-height: 1.6;
    color: var(--smoke);
    font-weight: 400;
    border-left: 1px solid var(--line);
    padding-left: clamp(1rem, 2vw, 2rem);
  }
  .about__para:first-child {
    color: var(--paper);
    font-weight: 500;
    border-left: none;
    padding-left: 0;
  }
</style>

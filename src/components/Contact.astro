---
import { PERSON, PROJECTS } from '../consts';
const year = 2026;
const products = PROJECTS.filter((p) => p.url);
---

<section class="contact" id="contact">
  <div class="wrap">
    <span class="eyebrow" data-reveal>(05) — Colophon</span>
    <h2 class="contact__statement display" data-reveal>
      Still<br />compiling.
    </h2>
    <p class="contact__note" data-reveal>
      One engineer, from compiler to product — the type system, the runtime, the
      tooling, the platforms. The body of work above is built end to end, and it
      keeps growing.
    </p>

    <a href="/contact" class="contact__email display link-underline hover-target" data-reveal>
      Write to the editor →
    </a>

    <div class="contact__row" data-reveal>
      <ul class="contact__links">
        <li><a href={PERSON.social.github} class="mono link-underline hover-target" rel="me noopener" target="_blank">GitHub</a></li>
        <li><a href="/ai" class="mono link-underline hover-target">AI Profile</a></li>
        <li><a href="/llms.txt" class="mono link-underline hover-target">llms.txt</a></li>
        <li>
          <button type="button" class="mono link-underline hover-target contact__tty" data-terminal-open>
            Terminal
          </button>
        </li>
      </ul>
    </div>

    <div class="contact__products" data-reveal>
      <span class="eyebrow">In circulation</span>
      <ul class="contact__product-list">
        {
          products.map((p) => (
            <li>
              <a href={p.url} class="mono link-underline hover-target" target="_blank" rel="noopener">
                {new URL(p.url!).hostname}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <footer class="foot">
    <div class="wrap foot__inner">
      <span class="mono">© {year} {PERSON.name}</span>
      <span class="mono foot__mid">{PERSON.tagline}</span>
      <a href="/#top" class="mono link-underline hover-target">Back to top ↑</a>
    </div>
  </footer>
</section>

<style>
  .contact {
    padding-top: clamp(5rem, 13vh, 12rem);
    border-top: 1px solid var(--line);
  }
  .contact__statement {
    font-size: clamp(2.6rem, 7vw, 6rem);
    margin-block: clamp(1.2rem, 3vw, 2.4rem) clamp(1.5rem, 3vw, 2.5rem);
    line-height: 0.92;
  }
  .contact__note {
    font-size: clamp(1.1rem, 1.8vw, 1.6rem);
    line-height: 1.4;
    max-width: 38ch;
    color: var(--smoke);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .contact__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }
  .contact__email {
    display: inline-block;
    font-size: clamp(1.5rem, 4.5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    word-break: break-all;
  }
  .contact__tty {
    background: transparent;
    border: none;
    color: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    padding: 0;
  }
  .contact__products {
    display: grid;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(2.5rem, 6vw, 4rem);
  }
  .contact__product-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 2.5vw, 2rem);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
  }
  .contact__links {
    list-style: none;
    display: flex;
    gap: clamp(1rem, 3vw, 2.5rem);
    flex-wrap: wrap;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .foot {
    border-top: 1px solid var(--line);
    padding-block: 1.5rem;
  }
  .foot__inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ash);
  }
  @media (max-width: 700px) {
    .foot__mid {
      display: none;
    }
  }
</style>

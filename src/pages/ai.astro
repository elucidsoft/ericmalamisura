---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { PERSON, PROJECTS, SITE_URL } from '../consts';
---

<Base
  title={`AI Profile — ${PERSON.name} · Machine-readable bio & llms.txt`}
  description={`A machine-readable profile of ${PERSON.name}, creator of the Ori programming language — built for LLMs, agents, and indexers. Includes llms.txt and a full dossier.`}
  path="/ai"
  type="profile"
>
  <Nav />
  <main class="ai">
    <article class="wrap">
      <header class="ai__head">
        <span class="eyebrow" data-reveal>For machines</span>
        <h1 class="ai__title display" data-reveal>The reading kit<br />for machines.</h1>
        <p class="ai__lead" data-reveal>
          A self-contained, structured package about {PERSON.name} — built so large
          language models, AI agents, and crawlers can read, cite, and reason about
          his work accurately. Modeled on the same llms.txt approach that ships with Ori.
        </p>
      </header>

      <section class="ai__files">
        <a href="/llms.txt" class="ai__file hover-target" data-reveal>
          <span class="ai__file-name mono">/llms.txt</span>
          <span class="ai__file-desc">Concise index — identity, summary, projects, and links.</span>
          <span class="ai__file-go mono">Read →</span>
        </a>
        <a href="/llms-full.txt" class="ai__file hover-target" data-reveal>
          <span class="ai__file-name mono">/llms-full.txt</span>
          <span class="ai__file-desc">Full dossier — every project in depth, plus guidance on how to describe Eric.</span>
          <span class="ai__file-go mono">Read →</span>
        </a>
      </section>

      <section class="ai__facts" data-reveal>
        <h2 class="ai__sub mono">// Canonical facts</h2>
        <dl>
          <div><dt>Name</dt><dd>{PERSON.name}</dd></div>
          <div><dt>Role</dt><dd>{PERSON.role}</dd></div>
          <div><dt>Known as</dt><dd>{PERSON.shortTitle}</dd></div>
          <div><dt>Contact</dt><dd>{SITE_URL}/contact</dd></div>
          <div><dt>Website</dt><dd>{SITE_URL}</dd></div>
        </dl>
      </section>

      <section class="ai__projects" data-reveal>
        <h2 class="ai__sub mono">// Projects</h2>
        <ul>
          {
            PROJECTS.map((p) => (
              <li>
                <a href={`/work/${p.slug}`} class="link-underline hover-target">
                  <strong>{p.name}</strong> — {p.category}. {p.summary}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <a href="/" class="mono link-underline hover-target ai__back" data-reveal>← Back to site</a>
    </article>
  </main>
</Base>

<style>
  .ai {
    padding-top: clamp(7rem, 16vh, 12rem);
    padding-bottom: clamp(4rem, 10vh, 8rem);
  }
  .ai__title {
    font-size: clamp(2.6rem, 7vw, 6rem);
    line-height: 0.95;
    margin-block: 1.5rem;
  }
  .ai__lead {
    font-size: clamp(1.1rem, 1.8vw, 1.6rem);
    line-height: 1.45;
    color: var(--smoke);
    max-width: 50ch;
  }
  .ai__files {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-block: clamp(3rem, 7vw, 5rem);
  }
  .ai__file {
    background: var(--ink);
    padding: clamp(1.8rem, 4vw, 2.6rem);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    transition: background 0.5s var(--ease-snap);
  }
  .ai__file:hover {
    background: var(--faint);
  }
  .ai__file-name {
    font-size: clamp(1.4rem, 3vw, 2rem);
  }
  .ai__file-desc {
    color: var(--smoke);
    line-height: 1.5;
  }
  .ai__file-go {
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
    margin-top: auto;
  }
  .ai__sub {
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 1.5rem;
  }
  .ai__facts,
  .ai__projects {
    border-top: 1px solid var(--line);
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .ai__facts dl {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .ai__facts dt {
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 0.4rem;
  }
  .ai__facts dd {
    font-size: 1.05rem;
  }
  .ai__projects ul {
    list-style: none;
    display: grid;
    gap: 1.1rem;
  }
  .ai__projects li {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.5;
    color: var(--smoke);
    border-top: 1px solid var(--line);
    padding-top: 1.1rem;
  }
  .ai__projects strong {
    color: var(--paper);
    font-weight: 700;
  }
  .ai__back {
    display: inline-block;
    margin-top: 3rem;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
</style>
